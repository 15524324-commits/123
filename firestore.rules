// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: questions
// Document ID: auto-generated
// Fields:
//   - userId: string (required) - The UID of the user who owns this record.
//   - originalImageUrl: string (optional) - URL of the uploaded image.
//   - originalText: string (required) - OCR extracted text.
//   - knowledgePoint: string (optional) - The main knowledge point.
//   - variations: list (required) - Array of objects {question, answer, analysis}.
//   - createdAt: timestamp (required) - Creation time.
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidQuestion(data) {
      return data.userId is string &&
             data.originalText is string && data.originalText.size() < 5000 &&
             data.variations is list && data.variations.size() <= 5 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /questions/{questionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidQuestion(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.userId == resource.data.userId &&
                      isValidQuestion(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
